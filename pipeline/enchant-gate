#!/usr/bin/env bash
# pipeline/enchant-gate <Emacs.app> [label] — the bundled-enchant FUNCTIONAL gate.
#
# Single source of truth for "does the shipped enchant actually spell-check?", shared by:
#   - pipeline/cleanroom  (local + CI, against build/<v>/Emacs.app with the pixi env moved aside)
#   - scripts/e2e-aqua-install.sh (in the clean pregate VM, against the mise-installed app)
#
# The relocate otool gate proves the bundle is self-contained as Mach-O but CANNOT see dlopen/data
# (providers are dlopen'd; the dict + ordering are plain files). THIS is the gate that proves the
# bundled providers + dict resolve and spell-check. It compiles a tiny probe against ONLY the app's
# bundled SDK (explicit -I/-L + an absolute rpath into the app's Frameworks) — exactly how
# site-start.el wires jinx's first-use `cc` compile (no pkg-config) — then checks en_US through both
# the shipped AppleSpell config and a bundled-hunspell ordering, from BOTH a standalone C program and
# an Emacs native module (the real jinx path). HARD gate: any failure exits non-zero. Requires clang
# (callers that may run without it — e.g. a VM — must guard with `command -v clang`).
set -euo pipefail
APP="${1:?usage: enchant-gate <Emacs.app> [label]}"
LABEL="${2:-$(basename "$(dirname "$APP")")}"
[ -d "$APP" ] || { echo "FATAL: $APP missing"; exit 1; }
command -v clang >/dev/null 2>&1 || { echo "FATAL: clang required (jinx compiles its module with cc)"; exit 1; }

SDK="$APP/Contents/Resources/enchant-sdk"
FW="$APP/Contents/Frameworks"
EMACS_INCLUDE="$APP/Contents/Resources/include"
SHIM="$SDK/include/misemacs-jinx-enchant-env.h"
[ -d "$SDK" ] || { echo "FATAL: $SDK missing — enchant not bundled by relocate"; exit 1; }
[ -f "$SDK/config/AppleSpell.config" ] || { echo "FATAL: $SDK/config/AppleSpell.config missing"; exit 1; }
[ -f "$SDK/config/enchant.ordering" ] || { echo "FATAL: $SDK/config/enchant.ordering missing"; exit 1; }
[ -f "$SHIM" ] || { echo "FATAL: $SHIM missing — jinx native env bridge not bundled"; exit 1; }

WORK="$(mktemp -d)"
trap 'rm -rf "$WORK"' EXIT
export HOME="$WORK"   # hermetic: any per-user enchant seeding lands in the throwaway HOME

echo ">> [$LABEL] enchant functional gate: AppleSpell + bundled hunspell (C + Emacs native module)"

cat > "$WORK/probe.c" <<'EOF'
#include <enchant.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
struct probe_result { char provider[64]; };
static void describe_cb(const char * const lang_tag, const char * const provider_name,
                        const char * const provider_desc, const char * const provider_file, void *data) {
  (void)lang_tag; (void)provider_desc; (void)provider_file;
  snprintf(((struct probe_result *)data)->provider, sizeof(((struct probe_result *)data)->provider),
           "%s", provider_name ? provider_name : "");
}
int main(int argc, char **argv) {
  const char *lang = argc > 1 ? argv[1] : "en_US";
  const char *expected_provider = argc > 2 ? argv[2] : "";
  EnchantBroker *b = enchant_broker_init();
  if (!b) { fprintf(stderr, "FAIL: enchant_broker_init returned NULL\n"); return 2; }
  EnchantDict *d = enchant_broker_request_dict(b, lang);
  if (!d) { fprintf(stderr, "FAIL: no dictionary for %s\n", lang); return 3; }
  struct probe_result result = {0};
  enchant_dict_describe(d, describe_cb, &result);
  int misspelled = enchant_dict_check(d, "helllo", strlen("helllo"));
  int correct = enchant_dict_check(d, "hello", strlen("hello"));
  fprintf(stderr, "   provider=%s helllo=%d hello=%d ENCHANT_CONFIG_DIR=%s\n",
          result.provider[0] ? result.provider : "(nil)", misspelled, correct, getenv("ENCHANT_CONFIG_DIR"));
  int ok = misspelled > 0 && correct == 0;
  if (expected_provider[0] && strcmp(result.provider, expected_provider) != 0) {
    fprintf(stderr, "FAIL: expected provider %s, got %s\n", expected_provider,
            result.provider[0] ? result.provider : "(nil)");
    ok = 0;
  }
  enchant_broker_free_dict(b, d);
  enchant_broker_free(b);
  return ok ? 0 : 1;
}
EOF
clang -I"$SDK/include" -L"$FW" -Wl,-rpath,"$FW" -lenchant-2 "$WORK/probe.c" -o "$WORK/probe"
echo "   probe compiled against the bundle (system clang)"

check_config() {  # <name> <config-dir> <expected-provider>
  local name="$1" cfg="$2" expected_provider="$3"
  [ -f "$cfg/enchant.ordering" ] || { echo "   FAIL: $name missing enchant.ordering"; return 1; }
  if ! ENCHANT_CONFIG_DIR="$cfg" "$WORK/probe" en_US "$expected_provider"; then
    echo "   FAIL: $name did not spell-check en_US with $expected_provider"; return 1
  fi
  echo "   $name: OK ($expected_provider flagged 'helllo', accepted 'hello')"
}

SHIPPED_CFG="$WORK/cfg-shipped"; mkdir -p "$SHIPPED_CFG"; cp -R "$SDK/config/." "$SHIPPED_CFG/"
check_config shipped "$SHIPPED_CFG" AppleSpell
HUNSPELL_CFG="$WORK/cfg-hunspell"; mkdir -p "$HUNSPELL_CFG/hunspell"
cp "$SDK/config/hunspell/"en_US.* "$HUNSPELL_CFG/hunspell/" 2>/dev/null || true
printf '%s\n' '*:hunspell,AppleSpell' > "$HUNSPELL_CFG/enchant.ordering"
check_config hunspell "$HUNSPELL_CFG" hunspell

echo "   Emacs native module probes (the same native env bridge + absolute bundle rpath jinx uses)"
cat > "$WORK/emacs-enchant-probe.c" <<'EOF'
#include <emacs-module.h>
#include <enchant.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#ifndef MISEMACS_EXPECTED_PROVIDER
#define MISEMACS_EXPECTED_PROVIDER ""
#endif
int plugin_is_GPL_compatible;
struct probe_result { char provider[64]; };
static void describe_cb(const char * const lang_tag, const char * const provider_name,
                        const char * const provider_desc, const char * const provider_file, void *data) {
  (void)lang_tag; (void)provider_desc; (void)provider_file;
  snprintf(((struct probe_result *)data)->provider, sizeof(((struct probe_result *)data)->provider),
           "%s", provider_name ? provider_name : "");
}
static emacs_value probe(emacs_env *env, ptrdiff_t nargs, emacs_value args[], void *data) {
  (void)nargs; (void)args; (void)data;
  EnchantBroker *broker = enchant_broker_init();
  if (!broker) { fprintf(stderr, "   Emacs module: no enchant broker\n"); return env->intern(env, "nil"); }
  EnchantDict *dict = enchant_broker_request_dict(broker, "en_US");
  if (!dict) { fprintf(stderr, "   Emacs module: no en_US dict\n"); enchant_broker_free(broker); return env->intern(env, "nil"); }
  struct probe_result result = {0};
  enchant_dict_describe(dict, describe_cb, &result);
  int misspelled = enchant_dict_check(dict, "helllo", strlen("helllo"));
  int correct = enchant_dict_check(dict, "hello", strlen("hello"));
  fprintf(stderr, "   Emacs module: provider=%s helllo=%d hello=%d ENCHANT_CONFIG_DIR=%s\n",
          result.provider[0] ? result.provider : "(nil)", misspelled, correct, getenv("ENCHANT_CONFIG_DIR"));
  int ok = misspelled > 0 && correct == 0;
  if (MISEMACS_EXPECTED_PROVIDER[0] && strcmp(result.provider, MISEMACS_EXPECTED_PROVIDER) != 0) {
    fprintf(stderr, "   Emacs module: expected provider %s, got %s\n", MISEMACS_EXPECTED_PROVIDER,
            result.provider[0] ? result.provider : "(nil)");
    ok = 0;
  }
  enchant_broker_free_dict(broker, dict);
  enchant_broker_free(broker);
  return env->intern(env, ok ? "t" : "nil");
}
int emacs_module_init(struct emacs_runtime *runtime) {
  emacs_env *env = runtime->get_environment(runtime);
  emacs_value symbol = env->intern(env, "misemacs-enchant-probe");
  emacs_value function = env->make_function(env, 0, 0, probe, "Probe bundled enchant.", NULL);
  env->funcall(env, env->intern(env, "defalias"), 2, (emacs_value[]){symbol, function});
  return 0;
}
EOF
run_module_probe() { # <name> <config-dir> <expected-provider>
  local name="$1" cfg="$2" expected_provider="$3"
  local module="$WORK/emacs-enchant-probe-$name.dylib"
  clang -I"$SDK/include" -I"$EMACS_INCLUDE" -include "$SHIM" \
    "-DMISEMACS_ENCHANT_CONFIG_DIR=\"$cfg\"" "-DMISEMACS_EXPECTED_PROVIDER=\"$expected_provider\"" \
    -L"$FW" -Wl,-rpath,"$FW" -lenchant-2 -fPIC -shared \
    "$WORK/emacs-enchant-probe.c" -o "$module"
  "$APP/Contents/MacOS/Emacs" -Q --batch \
    --eval "(progn (module-load \"$module\") (unless (misemacs-enchant-probe) (error \"native module enchant probe failed for $name\")) (princ \"   Emacs module $name: OK (native ENCHANT_CONFIG_DIR -> $expected_provider)\\n\"))"
}
run_module_probe shipped "$SHIPPED_CFG" AppleSpell
MODULE_HUNSPELL_CFG="$WORK/cfg-emacs-module-hunspell"; mkdir -p "$MODULE_HUNSPELL_CFG/hunspell"
cp "$SDK/config/hunspell/"en_US.* "$MODULE_HUNSPELL_CFG/hunspell/" 2>/dev/null || true
printf '%s\n' '*:hunspell,AppleSpell' > "$MODULE_HUNSPELL_CFG/enchant.ordering"
run_module_probe hunspell "$MODULE_HUNSPELL_CFG" hunspell

echo ">> [$LABEL] enchant-gate PASS — AppleSpell + bundled hunspell spell-check from C and Emacs native modules"
