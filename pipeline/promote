#!/usr/bin/env bash
# pipeline/promote --repo <owner/repo> --tag <tag> [--version master] [--attach "t1 t2 …"] —
# attach build-manifest.json (idempotent via --clobber, P6) to <tag> AND each --attach tag,
# then flip the Latest marker
# (atomic + reversible, P3). LAB-ONLY in Phase 4 (G2); the real repo's first promote
# is Phase 5's first kept release. Rerun-safe: just run it again after any failure.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO=""; TAG=""; VERSION="master"; MANIFEST=""; ATTACH=""
while [ $# -gt 0 ]; do
  case "$1" in
    --repo)     REPO="${2:?}"; shift 2 ;;
    --tag)      TAG="${2:?}"; shift 2 ;;
    --version)  VERSION="${2:?}"; shift 2 ;;
    --manifest) MANIFEST="${2:?}"; shift 2 ;;
    --attach)   ATTACH="${2:?}"; shift 2 ;;   # extra built tags to also carry the manifest (space-sep)
    *) echo "FATAL: unknown arg $1"; exit 1 ;;
  esac
done
[ -n "$REPO" ] && [ -n "$TAG" ] || { echo "usage: pipeline/promote --repo <owner/repo> --tag <tag>"; exit 1; }
if [ "$REPO" = "djgoku/misemacs" ] && [ "${MISEMACS_PUBLISH_OK:-}" != "1" ]; then
  echo "FATAL: promoting on djgoku/misemacs requires MISEMACS_PUBLISH_OK=1 (G8 interlock)"; exit 1
fi
# Derive channel from the tag (emacs-<channel>-YYYY-MM-DD[.N]) and assert the repo.
CH="$(printf '%s' "$TAG" | sed -E 's/^emacs-(.+)-[0-9]{4}-[0-9]{2}-[0-9]{2}(\.[0-9]+)?$/\1/')"
EXPECTED_REPO="${MISEMACS_ARTIFACT_BASE:-djgoku/misemacs}-emacs-$CH"
if [ "$CH" = "$TAG" ] || [ "$REPO" != "$EXPECTED_REPO" ]; then
  echo "FATAL: promote --repo '$REPO' / --tag '$TAG' — expected repo '$EXPECTED_REPO' (channel '$CH')"; exit 1
fi
if [ -n "$MANIFEST" ]; then
  # Phase-5 finalize path: caller supplies the merged manifest; the release + assets already
  # exist on GitHub (published by the build cell — possibly a different runner), so NO local
  # dist/ lookups (no SHA_FILE, no asset existence check).
  [ -f "$MANIFEST" ] || { echo "FATAL: --manifest $MANIFEST not found"; exit 1; }
  MANIFEST_PATH="$MANIFEST"
else
  # Phase-4 local path: compute the single-version manifest from dist/<version>/.
  SHA_FILE="$HERE/dist/$VERSION/upstream-sha.txt"
  [ -f "$SHA_FILE" ] || { echo "FATAL: $SHA_FILE missing — run pipeline/package (or publish) first"; exit 1; }

  ASSET=""
  while IFS= read -r line; do
    case "$line" in asset=*) ASSET="${line#asset=}" ;; esac
  done < <(cd "$HERE/orchestrator" && mise exec -- mix release.names --tag "$TAG" --os macos --arch arm64)
  [ -n "$ASSET" ] && [ -f "$HERE/dist/$VERSION/$ASSET" ] || {
    echo "FATAL: $HERE/dist/$VERSION/$ASSET missing — does --tag match the packaged dist/ artifact?"; exit 1; }

  echo ">> [1] build-manifest.json via mix release.manifest (Core.Hash fingerprint)"
  (cd "$HERE/orchestrator" && mise exec -- mix release.manifest \
    --version "$VERSION" --tag "$TAG" --upstream-sha "$(cat "$SHA_FILE")" \
    --root "$HERE" --out "$HERE/dist/$VERSION/build-manifest.json")
  MANIFEST_PATH="$HERE/dist/$VERSION/build-manifest.json"
  MANIFEST_REPO="$(jq -r '.repo // empty' "$MANIFEST_PATH")"
  if [ -n "$MANIFEST_REPO" ] && [ "$MANIFEST_REPO" != "$REPO" ]; then
    echo "FATAL: generated manifest repo '$MANIFEST_REPO' (from --version '$VERSION') != --repo '$REPO'"; exit 1
  fi
fi

echo ">> [2] attach manifest (idempotent)"
gh release upload "$TAG" "$MANIFEST_PATH" --repo "$REPO" --clobber

# Attach the SAME merged manifest to every other built release so each one self-describes the
# full state (not just Latest). --clobber = idempotent/rerun-safe; skip $TAG (already done).
for t in $ATTACH; do
  [ "$t" = "$TAG" ] && continue
  echo ">> [2b] attach manifest to $t"
  gh release upload "$t" "$MANIFEST_PATH" --repo "$REPO" --clobber
done

echo ">> [3] flip Latest marker to $TAG"
gh release edit "$TAG" --repo "$REPO" --latest

echo ">> promote: PASS — $TAG is Latest on $REPO; manifest attached${ATTACH:+ to every built release}"
