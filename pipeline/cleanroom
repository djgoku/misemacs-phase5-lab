#!/usr/bin/env bash
# pipeline/cleanroom <version> — Phase 2 DoD: prove build/<version>/Emacs.app is fully self-contained
# by exercising it with the per-version pixi env moved aside. Three gates:
#   [1] dyld closure : Emacs --batch must launch (resolve its whole bundled dylib closure).
#   [2] GUI frame    : NS frame smoke (best-effort; needs a display/session).
#   [3] enchant      : compile a tiny enchant probe with the SAME flags site-start.el injects, then
#                      spell-check a known misspelling through BOTH providers (applespell + bundled
#                      hunspell). The otool gate (mix relocate) can't see dlopen/data — THIS proves
#                      the bundled providers dlopen + the dict resolves with no pixi env present.
# Default version: master. Run after `mise run build <v> && mise run relocate <v>`.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION="${1:-master}"
APP="$HERE/build/$VERSION/Emacs.app"
ENV_DIR="$HERE/versions/$VERSION/.pixi"
[ -d "$APP" ] || { echo "FATAL: $APP missing — run 'mise run build $VERSION && mise run relocate $VERSION' first"; exit 1; }

ASIDE="$(mktemp -d)/pixi"
WORK="$(mktemp -d)"
restore() { [ -d "$ASIDE" ] && mv "$ASIDE" "$ENV_DIR"; }
trap 'restore; rm -rf "$WORK"' EXIT
# Hermetic HOME so the bundled site-start.el seeds its per-user enchant dir into the throwaway dir,
# not the real ~/.emacs.d.
export HOME="$WORK"

[ -d "$ENV_DIR" ] && mv "$ENV_DIR" "$ASIDE"
echo ">> pixi env moved aside ($ENV_DIR present? $([ -d "$ENV_DIR" ] && echo YES || echo NO))"

echo ">> [1] --batch (dyld must resolve the full bundled closure with the pixi env gone) — THE base gate"
"$APP/Contents/MacOS/Emacs" --batch --eval '(princ (format "ok %s\n" emacs-version))'

echo ">> [2] GUI frame smoke (NS path; needs a display/session — best-effort)"
if "$APP/Contents/MacOS/Emacs" -Q --eval '(run-with-timer 1 nil (lambda () (kill-emacs 0)))' 2>/dev/null; then
  echo "   GUI frame OK"
else
  echo "   GUI frame skipped (no display/session — --batch is the hard gate)"
fi

echo ">> [3] enchant functional gate: spell-check through the bundled providers (env gone)"
SDK="$APP/Contents/Resources/enchant-sdk"
FW="$APP/Contents/Frameworks"
[ -d "$SDK" ] || { echo "FATAL: $SDK missing — enchant not bundled by relocate"; exit 1; }

cat > "$WORK/probe.c" <<'EOF'
#include <enchant.h>
#include <stdio.h>
#include <string.h>
/* exit 0 iff `word` is flagged misspelled for `lang` (proves the provider + dict resolve). */
int main(int argc, char **argv) {
  const char *lang = argc > 1 ? argv[1] : "en_US";
  const char *word = argc > 2 ? argv[2] : "helllo";
  EnchantBroker *b = enchant_broker_init();
  if (!b) { fprintf(stderr, "FAIL: enchant_broker_init returned NULL\n"); return 2; }
  EnchantDict *d = enchant_broker_request_dict(b, lang);
  if (!d) { fprintf(stderr, "FAIL: no dictionary for %s\n", lang); return 3; }
  int bad = enchant_dict_check(d, word, strlen(word));
  fprintf(stderr, "   check(%s, \"%s\") = %d\n", lang, word, bad);
  enchant_broker_free_dict(b, d);
  enchant_broker_free(b);
  return bad > 0 ? 0 : 1;
}
EOF

# Compile against the BUNDLED enchant SDK exactly as site-start.el wires jinx's first-use compile
# (no pkg-config), with an absolute rpath to the app's Frameworks (the probe lives outside the app).
clang -I"$SDK/include" -L"$FW" -Wl,-rpath,"$FW" -lenchant-2 "$WORK/probe.c" -o "$WORK/probe"
echo "   probe compiled against the bundle (system clang; pixi env gone)"

check_provider() {  # <name> <ordering-line>
  local name="$1" ordering="$2" cfg="$WORK/cfg-$1"
  mkdir -p "$cfg/hunspell"
  cp "$SDK/config/hunspell/"en_US.* "$cfg/hunspell/" 2>/dev/null || true
  printf '%s\n' "$ordering" > "$cfg/enchant.ordering"
  if ! ENCHANT_CONFIG_DIR="$cfg" "$WORK/probe" en_US helllo; then
    echo "   FAIL: $name did not flag misspelled 'helllo'"; return 1
  fi
  if ENCHANT_CONFIG_DIR="$cfg" "$WORK/probe" en_US hello; then
    echo "   FAIL: $name flagged correct 'hello' as misspelled"; return 1
  fi
  echo "   $name: OK (flagged 'helllo', accepted 'hello')"
}

check_provider applespell '*:applespell'
check_provider hunspell   '*:hunspell'

echo ">> cleanroom: PASS — $VERSION app self-contained; enchant spell-checks via BOTH providers (no pixi env)"
